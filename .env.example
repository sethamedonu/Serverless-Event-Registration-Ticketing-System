# Copy to .env and fill in all values after running: sam deploy
# Get these from the CloudFormation stack outputs

VITE_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com/prod
VITE_COGNITO_USER_POOL_ID=<UserPoolId from SAM output>
VITE_COGNITO_CLIENT_ID=<UserPoolClientId from SAM output>
VITE_AWS_REGION=<your-region>
